; ============================================
; Mummy.tscn - 木乃伊怪物场景
; ============================================
; 这个场景定义了 Mummy（木乃伊）怪物的所有属性和节点。
;
; 使用的脚本：Scripts/monster_archer.gd
;   继承关系：MonsterBase -> MonsterRanged -> MonsterArcher
;
; 怪物特点：
; - 远程攻击：使用弓箭射击玩家
; - 保持距离：不会靠近玩家，而是保持 optimal_range 距离
; - 攻击前摇：0.5秒瞄准 → 发射 → 1.5秒后摇
; - 逃跑机制：玩家太靠近时会反向逃跑
;
; 贴图：../manual_extracted/Pictures/Mummy.png
;   原版游戏中的 Mummy（木乃伊）
; ============================================

[gd_scene load_steps=5 format=3]

; 外部资源引用
[ext_resource type="Script" path="res://Scripts/Monsters/monster_mummy.gd" id="1_archer"]
; 脚本：怪物行为逻辑（远程攻击、保持距离等）

[ext_resource type="Texture2D" path="res://Art/Placeholder/monster_mummy_walk.png" id="2_archer"]
; 贴图：怪物外观（原版 Mummy 贴图）

[ext_resource type="PackedScene" path="res://Scenes/MonsterArrow.tscn" id="3_arrow"]
; 弓箭场景：发射的投射物

; 碰撞形状定义
[sub_resource type="RectangleShape2D" id="RectangleShape2D_archer"]
size = Vector2(32, 32)
; 碰撞体积：32x32 像素，所有怪物统一大小

; ============================================
; 根节点：Mummy
; ============================================
[node name="Mummy" type="CharacterBody2D" groups=["monsters"]]
; CharacterBody2D：带有碰撞检测的角色实体
collision_layer = 4
; 碰撞层：第3层（怪物层）
collision_mask = 2
; 检测层：第2层（英雄/玩家层）

script = ExtResource("1_archer")
; 绑定脚本：monster_archer.gd

; ---------- 远程怪物特有属性 ----------
optimal_range = 400.0
; 最优攻击距离

too_close_range = 150.0
; 逃跑距离：小于此距离会反向逃跑

arrow_scene = ExtResource("3_arrow")
; 弓箭场景：发射的投射物（MonsterArrow.tscn）

; ============================================
; 子节点
; ============================================

[node name="CollisionShape2D" type="CollisionShape2D" parent="."]
; 碰撞形状：用于物理碰撞检测
shape = SubResource("RectangleShape2D_archer")
; 使用上面定义的 32x32 矩形

[node name="Sprite2D" type="Sprite2D" parent="."]
; 精灵节点：显示怪物贴图
texture = ExtResource("2_archer")
; 使用 mummy.png 贴图
region_enabled = true
region_rect = Rect2(0, 0, 48, 48)

[node name="HealthBar" type="ProgressBar" parent="."]
; 血条：显示怪物当前血量
visible = false
; 默认隐藏，受伤时才显示
offset_left = -16.0
offset_top = -32.0
offset_right = 16.0
offset_bottom = -24.0
; 位置和大小：在怪物头顶
z_index = 10
; 层级：确保血条显示在其他元素上方
value = 100.0
; 默认值（会被脚本覆盖）
show_percentage = false
; 不显示百分比数字
self_modulate = Color(1, 0.2, 0.2, 1)
; 颜色：红色

[node name="StateTimer" type="Timer" parent="."]
; 状态计时器：控制状态切换（如受击恢复）
one_shot = true
; 一次性计时器，超时后停止

[node name="AttackCooldown" type="Timer" parent="."]
; 攻击冷却计时器：控制攻击间隔
one_shot = true
; 一次性计时器
